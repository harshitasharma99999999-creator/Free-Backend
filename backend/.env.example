# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── CORS (comma-separated frontend origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/free-api

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Ollama (local LLM — powers /eior/v1 chat, vibecode, embeddings) ─────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=eior
# Model for /eior/v1/embeddings (must support embeddings, e.g. nomic-embed-text)
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text

# Optional: map public EIOR model IDs to specific Ollama model names
# (useful if you run multiple local models in Ollama).
EIOR_OLLAMA_MODEL_V1=eior
EIOR_OLLAMA_MODEL_ADVANCED=eior
EIOR_OLLAMA_MODEL_CODER=eior

# ─── Replicate AI (for /eior/v1/images/generations) ─────────────────────────
# Get from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here
REPLICATE_IMAGE_MODEL=stability-ai/sdxl:39ed52f2319f9c4ef73a8f9b3491c6cb3d0a0c2ddb1a73571e5ac5efbe3d18e7
REPLICATE_VIDEO_MODEL=anotherjesse/zeroscope-v2-xl:9f747673945c62801b13b84701c783929c0ee784e4748ec062204894dda1a351
CREDIT_COST_IMAGE=1
CREDIT_COST_VIDEO=5

# ─── Rate Limiting (Upstash Redis — optional, falls back to in-memory) ───────
# Get from https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
# Requests allowed per window per API key (default: 100 / 60s)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ─── Stripe Payments (optional) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRO_PRICE_ID=price_your_price_id

# ─── VPS Provisioning (Hetzner Cloud) ─────────────────────────────────────────
# Get from https://console.hetzner.cloud → Security → API Tokens → Generate token (Read & Write)
# Without this, the /api/vps routes return 503 — all other routes work fine.
HETZNER_API_TOKEN=your_hetzner_api_token_here
