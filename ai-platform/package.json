{
  "name": "eior-llm",
  "version": "1.0.0",
  "description": "Eior LLM — OpenAI-compatible AI platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:init": "psql $DATABASE_URL -f scripts/init-db.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^9.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "firebase-admin": "^12.1.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^8.21.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
