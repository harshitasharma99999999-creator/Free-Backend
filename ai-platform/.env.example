# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=https://free-backed.web.app

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Docker: postgresql://postgres:postgres@postgres:5432/ai_platform
# Local:  postgresql://postgres:postgres@localhost:5432/ai_platform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_platform

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Firebase Admin SDK (from Firebase Console → Service Accounts) ──────────────
FIREBASE_PROJECT_ID=free-backed
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@free-backed.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ── Text AI: Ollama (local) — primary provider ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Text AI: Groq (cloud) — fallback when Ollama is down ──────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── Image AI: Automatic1111 (local) — primary provider ────────────────────────
SD_BASE_URL=http://localhost:7860
SD_MODEL=dreamshaper_8

# ── Image + Video AI: Replicate (cloud) — fallback ────────────────────────────
REPLICATE_API_TOKEN=r8_your_token_here

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_RPD=1000

# ── API Key Settings ───────────────────────────────────────────────────────────
API_KEY_MAX_PER_USER=10
